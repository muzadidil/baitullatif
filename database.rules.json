{
  "rules": {
    ".read": "auth != null",
    ".write": false,

    "admin": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "master": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "struktur": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "kegiatan": {
      ".read": "auth != null",
      "$id": {
        ".write": "auth != null",
        ".validate": "!newData.exists() || newData.hasChildren(['nama', 'status'])",
        "nama":   { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
        "status": { ".validate": "newData.isString() && (newData.val() == 'aktif' || newData.val() == 'selesai')" },
        "dibuat": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },

    "kas": {
      ".read": "auth != null",
      "$buku": {
        ".write": "auth != null",
        "pengeluaran": {
          "$id": {
            ".write": "auth != null",
            ".validate": "!newData.exists() || newData.hasChildren(['pj', 'keterangan', 'total', 'kategori'])",
            "pj":         { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
            "jabatanPj":  { ".validate": "newData.isString() && newData.val().length <= 50" },
            "keterangan": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200" },
            "total":      { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "qty":        { ".validate": "newData.isNumber()" },
            "satuan":     { ".validate": "newData.isString() && newData.val().length <= 50" },
            "kategori":   { ".validate": "newData.isString() && newData.val().length <= 50" },
            "status":     { ".validate": "newData.isString()" },
            "waktu":      { ".validate": "newData.isNumber()" },
            "$other":     { ".validate": false }
          }
        },
        "pemasukan": {
          "$id": {
            ".write": "auth != null",
            ".validate": "!newData.exists() || newData.hasChildren(['pj', 'nominal'])",
            "pj":         { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
            "jabatanPj":  { ".validate": "newData.isString() && newData.val().length <= 50" },
            "nominal":    { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "keterangan": { ".validate": "newData.isString() && newData.val().length <= 200" },
            "kategori":   { ".validate": "newData.isString() && newData.val().length <= 50" },
            "waktu":      { ".validate": "newData.isNumber()" },
            "$other":     { ".validate": false }
          }
        },
        "$other": { ".validate": false }
      }
    },

    "pengurus": {
      ".read": "auth != null",
      "$id": {
        ".write": "auth != null",
        ".validate": "!newData.exists() || newData.hasChildren(['jabatan', 'nama'])",
        "jabatan":  { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50" },
        "nama":     { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
        "waktu":    { ".validate": "newData.isNumber()" },
        "$other":   { ".validate": false }
      }
    },

    "surat": {
      ".read": "auth != null",
      "$id": {
        ".write": "auth != null",
        ".validate": "!newData.exists() || newData.hasChildren(['nomor', 'jenis', 'tanggal'])",
        "nomor":    { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 60" },
        "jenis":    { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 30" },
        "tanggal":  { ".validate": "newData.isNumber()" },
        "perihal":  { ".validate": "newData.isString() && newData.val().length <= 150" },
        "tujuan":   { ".validate": "newData.isString() && newData.val().length <= 200" },
        "lampiran": { ".validate": "newData.isString() && newData.val().length <= 50" },
        "detail":   {},
        "pembuat":  { ".validate": "newData.isString() && newData.val().length <= 100" },
        "dibuat":   { ".validate": "newData.isNumber()" },
        "$other":   { ".validate": false }
      }
    },

    "suratCounter": {
      ".read": "auth != null",
      "$tahun": {
        ".write": "auth != null",
        ".validate": "newData.isNumber() && newData.val() >= 0"
      }
    }
  }
}
